#chromosome positions splliting in annotations table
anno$chromosome = sub(":.*", "", anno$LOCUS)
anno$start = as.numeric(sub(".*:(.*)-.*", "\\1", anno$LOCUS))
anno$end   = as.numeric(sub(".*-(.*)", "\\1", anno$LOCUS))
anno$position = (anno$start + anno$end) / 2

#adding a sig column to each of the two de tables
de_b_v_d$sig = as.factor(de_b_v_d$p.adj < 0.05 & abs(de_b_v_d$log2fold) > 1)
de_m_v_d$sig= as.factor(de_m_v_d$p.adj < 0.05 & abs(de_m_v_d$log2fold) > 1)
de_c_v_d$sig= as.factor(de_c_v_d$p.adj < 0.05 & abs(de_c_v_d$log2fold) > 1)


# merging the three DE tables
master_de= merge(de_b_v_d, de_m_v_d, by=0, suffixes=c(".b_v_d",".m_v_d"))
names(de_c_v_d)=c("log2fold.c_v_d","p.c_v_d","p.adj.c_v_d","sig.c_v_d")
master= merge(master_de, de_c_v_d, by.x=1, by.y=0)

master_temp=merge(em,anno, by.x=0, by.y=0)
master=merge(master_temp,master, by.x=1,by.y=1)  

row.names(master) = master$SYMBOL
master=na.omit(master[,-1])

#em_symbols and em scaled
em_symbols = master[ss$SAMPLE]
em_scaled = na.omit(data.frame(t(scale(t(em_symbols)))))
