ss = read.table("~/Documents/Modules/BIOL5421/assessment/part2/part2_datasets/P53_activation_AML/SS.csv", header = TRUE, sep="\t")
em = read.table("~/Documents/Modules/BIOL5421/assessment/part2/part2_datasets/P53_activation_AML/EM.csv", header = TRUE, row.names = 1, sep="\t")
de_combo_vs_DMSO=read.table("~/Documents/Modules/BIOL5421/assessment/part2/part2_datasets/P53_activation_AML/DE_Combo_vs_DMSO.csv",header = TRUE, row.names = 1, sep="\t")
