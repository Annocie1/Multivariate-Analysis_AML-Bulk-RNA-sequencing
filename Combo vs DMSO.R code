source("~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/function.r")


#subsetting ss,em to contain two groups
ss=ss[-c(4:9),]
em=em[,-c(4:9)]

#sample group colours for consistency
ss$SAMPLE_GROUP=factor(ss$SAMPLE_GROUP, levels=c("DMSO","Combo"))
sample_group_colours = c(DMSO="deepskyblue",Combo="darkgreen")
sample_group_label=c(DMSO="DMSO",Combo="Combo")

#Master parsing
master_temp=merge(em,anno, by.x=0, by.y=0)
master=merge(master_temp,de_combo_vs_DMSO, by.x=1,by.y=0) 

row.names(master) = master[ ,"SYMBOL"]
master = na.omit(master[,-c(1,8)])
master= master[order(master[ ,"p"], decreasing=FALSE),]

master$Row.means = rowMeans(master[,1:6])
master$mlog10p = -log10(master$p)
master$sig = as.factor(master$p.adj < 0.05 & abs(master$log2fold) > 1.0)

#sub-setting master and storing significant genes.
master_sig =subset(master, p.adj < 0.05 & abs(log2fold) >1)
sig_genes= row.names(master_sig)

master_sig_up = subset(master_sig, log2fold>1)
master_sig_up_top5 = master_sig_up[1:5,]
up_regulated_genes= row.names(master_sig_up)

master_sig_down = subset(master_sig,log2fold < -1)
master_sig_down_top5= master_sig_down[1:5,]
down_regulated_genes=row.names(master_sig_down)

#creating em_symbols and scaling and filtering for sig genes
em_symbols= master[, ss$SAMPLE]
em_scaled=na.omit(data.frame(t(scale(t(em_symbols)))))
em_scaled_sig=em_scaled[sig_genes, ]

#saving to the working directorate
write.table(em_symbols, file="~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/DE_Combo_vs_DMSO/em_symbols.csv", sep="\t")
write.table(em_scaled, file="~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/DE_Combo_vs_DMSO/em_scaled.csv", sep="\t")
write.table(master, file="~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/DE_Combo_vs_DMSO/master.csv", sep="\t")
write.table(master_sig, file="~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/DE_Combo_vs_DMSO/master_sig.csv", sep="\t")
write.table(em_scaled_sig, file="~/Documents/Modules/BIOL5421/assessment/part2/BIOL 5421 assessment 2/DE_Combo_vs_DMSOem_scaled_sig.csv", sep="\t")

